#!/bin/sh

# based on: https://github.com/MerryMens/AsusMerlin-WireGuard-Failover
# added args, killswitch, wan(s)/ping/dns/curl tests, logic changes, filename changes, etc

Log()
{
  echo ""; echo "====================================="
  msg=$logPrefix"$@"
  echo "=Log= $msg"
  escapedLoggerMsg=$(echo -e $msg)
  logger -c "$escapedLoggerMsg"
  echo "^^^==================^^^"
}

LogSlack()
{
  Log "$@"
  Slack "$@"
}

Slack()
{
  if [ "$logSlackPath" != "" ]; then
    escapedSlackMsg=$(echo $logPrefix"$*" | sed 's/ / /g' | sed 's/(/[/g' | sed 's/)/]/g') # replace space and brackets
    $logSlackPath $escapedSlackMsg &> /dev/null &
  fi
}

ParseArgs()
{
  fromClientConfig=$1
  shift
  echo "=== ParseArgs: fromClientConfig=$fromClientConfig $*"

  echo arg count: $#
  if [ $# -gt 1 ]; then
    unset var

    for arg in "${@:2}"; do
      echo "arg: $arg"

      if [[ ${arg:0:1} == '-' ]]; then
          if [ $arg == "--reset" ]; then
            SetDefaults
          elif [ $arg == "--disablewan1check" ]; then
            if [ $fromClientConfig -eq 0 ]; then
              echo set disableWan1Check: 1
              disableWan1Check=1
            else
              ArgCmdLineOnly $arg ""
            fi
          elif [ $arg == "--attachtorunningclient" ]; then
            if [ $fromClientConfig -eq 0 ]; then
              echo set attachToRunningClient: 1
              attachToRunningClient=1
            else
              ArgCmdLineOnly $arg ""
            fi
          elif [ $arg == "--qoneuccc" ]; then
            if [ $fromClientConfig -eq 0 ]; then
              echo set quitOnExternalAndUnmonitoredConfigChange: 1
              quitOnExternalAndUnmonitoredConfigChange=1
            else
              ArgCmdLineOnly $arg ""
            fi
          elif [ $arg == "--reload" ]; then
            echo set reloadClientConfigOnDiff: 1
            reloadClientConfigOnDiff=1
          else
            echo set var: \"$arg\"
            var=$arg
          fi
      else
          if [ -n "$var" ]; then
            # this works but spams "bad number" # if [ $arg -eq $arg ]; then
            if [ -z "${arg//[0-9]}" ]; then # this method would not recognise a negative number
              if [ $var == "-k" ]; then
                  echo set killswitch: $arg
                  killswitch=$arg
              elif [ $var == "-w" ]; then
                  echo set hsWait: $arg
                  hsWait=$arg
              elif [ $var == "-t" ]; then
                  echo set hsTimeout: $arg
                  hsTimeout=$arg
              elif [ $var == "-q" ]; then
                  echo set quitOnNoInterface: $arg
                  quitOnNoInterface=$arg
              elif [ $var == "-p" ]; then
                  echo set testPing: $arg
                  testPing=$arg
              elif [ $var == "-d" ]; then
                  echo set testDns: $arg
                  testDns=$arg
              elif [ $var == "-c" ]; then
                  echo set testCurl: $arg
                  testCurl=$arg
              elif [ $var == "-n" ]; then
                  if [ $arg -lt 1 ]; then
                    arg=1
                  fi
                  echo set logEveryNthHandshake: $arg
                  logEveryNthHandshake=$arg
              elif [ $var == "-a" ]; then
                  echo set wanWait: $arg
                  wanWait=$arg
              else
                LogSlack "unrecognised var \'$var\' - discarding that and arg \'$arg\'"
              fi
            else
              if [ $var == "--failoverconfigpath" ]; then
                if [ $fromClientConfig -eq 0 ]; then
                  echo set failoverConfigPath: $arg
                  failoverConfigPath=$arg
                else
                  ArgCmdLineOnly $var $arg
                fi
              elif [ $var == "--clientconfigdir" ]; then
                if [ $fromClientConfig -eq 0 ]; then
                  echo set clientConfigDir: $arg
                  clientConfigDir=$arg
                else
                  ArgCmdLineOnly $var $arg
                fi
              elif [ $var == "--logslackpath" ]; then
                if [ -f $arg ]; then
                  echo set logSlackPath: $arg
                  logSlackPath=$arg
                else
                  Log "logslackpath arg \'$arg\' file not found"
                fi
              elif [ $var == "-pt" ]; then
                echo set pingTargets: $arg
                pingTargets=$arg
              elif [ $var == "-dt" ]; then
                echo set nslookupTargets: $arg
                nslookupTargets=$arg
              elif [ $var == "-ct" ]; then
                echo set curlTargets: $arg
                pingTargets=$arg
              else
                LogSlack "param arg \'$arg\' for var \'$var\' is not a number - discarding both"
              fi
            fi
          else
            LogSlack "var is unset - discarding arg \'$arg\'"
          fi
          unset var
      fi
    done
    if [ -n "$var" ]; then
      LogSlack "var \'$var\' was not followed by param arg - discarded"
    fi
  fi
}

ArgCmdLineOnly()
{
  LogSlack "\'$1\' option is only valid from the command line' - discarding along with arg \'$2\'"
}

#ArgFailoverConfigOnly()
#{
#  LogSlack "\'$1\' option is only valid from within the failover config' - discarding along with arg \'$2\'"
#}

StartTimer()
{
  timerStart=$(date +%s)
}

StopTimer()
{
  return $(( $(date +%s) - $timerStart ))
}

ParamsString()
{
  # shellcheck disable=SC2028
  echo "params:\n\t\t[-k] kill switch: $killswitch\n\t\t[-w] handshake wait: $hsWait\n\t\t[-t] handshake timeout: $hsTimeout\n\t\t[-q] quit on no interface: $quitOnNoInterface\n\t\t[-p] test ping: $testPing\n\t\t[-d] test dns: $testDns\n\t\t[-c] test curl: $testCurl\n\t\t[-n] log every nth handshake: $logEveryNthHandshake\n\t\t[-a] WAN wait : $wanWait"
}

Exit()
{
  code=$1
  shift
  msg="EXITING:\n\texit code:\n\t\t$code\n\treason:\n\t\t""$@"
  if [ -n "$upSince" ]; then
    msg=$msg"\n\n\tfinal client config [$wgClientConfigFilePath], active since: $upSince\n "
  fi
  LogSlack $msg

  # negative code means show usage before exit
  if [ $code -ge 0 ]; then
    exit $code
  fi
  ShowUsage $(( $code * -1 )) # can't exit with negative code
}

# shellcheck disable=SC2329
OnTrap()
{
  sig=$?
  # why does ^C = 130?
  trap - SIGHUP SIGINT SIGQUIT SIGKILL SIGSTOP SIGABRT SIGALRM SIGFPE SIGILL SIGPIPE SIGSEGV SIGTERM SIGUSR1 SIGUSR2
  Exit 4 "trapped: $sig"
}

GetWanIfName()
{
  echo "=== GetWanIfName: $1"

  wan=""

  if [ $# -gt 0 ] && [ -z "${1//[0-9]}" ]; then
    # no arrays in sh, so longhand it is...
    if [ $1 -eq 0 ]; then
      wan=$wan0
      if [ "$wan" == "" ]; then
        wan=$(nvram get wan0_ifname)
        echo "===   wan0 was blank, fetched again: $wan"
        wan0=$wan
      fi
    elif [ $1 -eq 1 ]; then
      wan=$wan1
      if [ "$wan" == "" ]; then
        wan=$(nvram get wan1_ifname)
        echo "===   wan1 was blank, fetched again: $wan"
        wan1=$wan
      fi
    else
      echo "===   invalid wan index"
    fi
  fi

  if [ "$wan" == "" ]; then
    echo "===   blank interface name"
    return 0
  fi

  return 1
}

IsWanUp()
{
  echo "=== IsWanUp: $1"

  # check if wan is actually enabled first
  enabled=$(nvram get wan_enable)
  if [ $enabled -eq 0 ]; then
    echo "===  wan is disabled on router"
  else
    GetWanIfName $1
    if [ "$wan" != "" ]; then
      result=$(ethtool "$wan" 2>&1 | grep "Link detected:")
      echo "====   ethtool $wan: $result"
      if [ "$result" != "" ]; then
        result=`echo $result | awk '{print $3}'`
        echo "====     wan link test: $result"
        if [ "$result" == "yes" ]; then
          echo "===     wan $1 is UP"
          return 1
        fi
      fi
    fi
  fi

  echo "===   wan $1 is DOWN"
  return 0
}

WagWan()
{
  wait=$1
  echo "=== WagWan: $1"
  
  # check wan until it's up
  wanUp=0
  wasDown=0
  
  while true; do
    IsWanUp 0; wanUp=$?
    if [ $wanUp -eq 0 ]; then
      if [ $disableWan1Check -eq 0 ]; then
        # check wan1 only if wan set to failover/fallback mode ### UNTESTED ###
        wansMode=$(nvram get wans_mode)
        echo "===  wansMode: $wansMode"
        if [ "$wansMode" == "fb" ] || [ "$wansMode" == "fo" ]; then 
          IsWanUp 1; wanUp=$?
        fi
      fi
    fi

    if [ $wanUp -eq 1 ]; then
      # and we're done
      break
    fi

    if [ $wasDown -eq 0 ]; then
      wasDown=1
      wanDownSince=$(date)
      Log "CONNECTIVITY FAIL: WAN is DOWN, will silently check again every $wait seconds"
    fi

    sleep $wait
  done

  if [ $wasDown -eq 1 ]; then
    LogSlack "CONNECTIVITY RECOVERY: WAN is back UP, observed down at $wanDownSince"
  fi

  # returns 1 if was found to be down previously, in loop above
  return $wasDown
}

FindRunningClientConfig()
{
  echo "=== FindRunningClientConfig"
  runningDescr=$(nvram get "$wgc"_desc)
  echo "===  runningDescr: $runningDescr"

  clientConfigItem=0
  while read line; do
    if [ "$line" != "" ]; then
      fc=${line:0:1}
      if [ $fc  != '#' ] && [ $fc  != '-' ]; then
        clientConfigItem=$(( $clientConfigItem + 1 ))
        descr="$(echo $line | cut -d " " -f2)"
        if [ "$descr" == "$runningDescr" ]; then
          echo "===    found: $clientConfigItem"
          return $clientConfigItem
        fi
      fi
    fi
  done < "$wgFailoverConfigFilePath"
  return 0
}

DetectExternalRunningClientConfigChange()
{
  echo "=== DetectExternalRunningClientConfigChange"
  runningDescr=$(nvram get "$wgc"_desc)
  echo "===  runningDescr: $runningDescr"

  if [ "$wgClientDescription" == "$runningDescr" ]; then
    echo "===    no description change: 0"

    # check if current configs settings are the same on the router
    CompareClientConfigFile
    if [ "$compareClientConfigDiff" != "" ]; then
      printf "===    client settings \'$compareClientConfigDiff\' change on router: 3"
      return 3
    fi

    # continue with same client config
    return 0
  fi

  LogSlack "CONNECTIVITY CHANGE: the monitored client config \'$wgClientDescription\' has externally changed to \'$runningDescr\'"
  wgClientDescription=$runningDescr
  upSince=$(date) # somewhere between now and after prior handshake wait

  # is the new client config in the failover config?
  FindRunningClientConfig
  if [ $? -ne 0 ]; then
    echo "===    IN failover config: 1"

    # check if current configs settings are the same on the router
    CompareClientConfigFile
    if [ "$compareClientConfigDiff" != "" ]; then
      printf "===    client settings \'$compareClientConfigDiff\' change on router: 3(b)"
      return 3
    fi

    # continue with new config
    return 1
  fi

  if [ $reloadClientConfigOnDiff -ne 0 ]; then
    echo "===    NOT in failover config: 4"
    # will try next client config
    return 4
  fi

  echo "===    NOT in failover config: 2"
  return 2
}


readonly maxWgc=5
readonly wanUpAgainWait=15

# defaults
readonly _killswitch=1
readonly _hsWait=180
readonly _hsTimeout=300
readonly _quitOnNoInterface=0
readonly _testPing=1
readonly _testDns=1
readonly _testCurl=1
