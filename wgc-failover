Init()
{
  logPrefix="wgc-failover: "

  # try and keep track of unexpected terminations
  trap OnTrap SIGHUP SIGINT SIGQUIT SIGABRT SIGALRM SIGFPE SIGILL SIGPIPE SIGSEGV SIGTERM SIGUSR1 SIGUSR2

  if [ $# -eq 0 ] || [ $1 == "-h" ] || [ $1 == "--help" ]; then
    ShowUsage
  fi

  SetDefaults
  # not reset by SetDefaults
  failoverConfigPath=""
  clientConfigDir=""
  logSlackPath=""

  Log "command line: $0 $@"

  # parse args
  #   - first is client number
  echo "=== client num arg is: $1"
  if [ $1 -eq $1 ] && [ $1 -gt 0 ] && [ $1 -le $maxWgc ]; then
    echo set client num: $1
    clientNum=$1
  else
    Exit -1 "ARGUMENT FAIL: client number \'$1\' is invalid"
  fi
  wgc="wgc"$clientNum

  # fetch wan interface names
  wan0=$(nvram get wan0_ifname)
  wan1=$(nvram get wan1_ifname)

  logPrefix="wgc-failover[$clientNum]: "

  #   - optional switch/value pair args
  ParseArgs 0 $@

  # send command line to slack, if path now set
  Slack "command line: $0 $@"

  # check overridden failover config path
  if [ "$failoverConfigPath" != "" ]; then
    if ! [ -f $failoverConfigPath ]; then
      Exit 6 "ARGUMENT/FILE FAIL: failover config path \'$failoverConfigPath\' is invalid"
    fi
  fi

  # check overridden client configs dir
  if [ "$clientConfigDir" != "" ]; then
    if ! [ -d $clientConfigDir ]; then
      Exit 9 "ARGUMENT/FILE FAIL: client config dir \'$clientConfigDir\' is invalid"
    fi
  fi

  # figure out config paths

  if [ "$failoverConfigPath" != "" ]; then
    wgFailoverConfigFilePath=$failoverConfigPath
  else
    wgFailoverConfigFilePath="/jffs/configs/wgc-failover-$clientNum.conf"  

    if ! [ -f $wgFailoverConfigFilePath ]; then
      Exit 7 "FILE FAIL: failover config path \'$wgFailoverConfigFilePath\' is invalid"
    fi
  fi

  if [ "$clientConfigDir" != "" ]; then
    wgClientConfigFilesDir=$clientConfigDir
  else
    wgClientConfigFilesDir="/jffs/configs/wgc-failover-client-$clientNum-configs"

    if ! [ -d $wgClientConfigFilesDir ]; then
      Exit 10 "FILE FAIL: clients config dir \'$wgClientConfigFilesDir\' is invalid"
    fi
  fi
}

##############################################################################
Main()
{
  # wait for wan up
  WagWan 15

  # and for NTP
  WaitForNTP

  runningConfigItem=0
  clientConfigSucc=0

  # run forever
  while true
  do
    LogSlack "Loading failover config: $wgFailoverConfigFilePath"
    sleep 1

    if [ $attachToRunningClient -ne 0 ]; then
      FindRunningClientConfig
      runningConfigItem=$?
      if [ $runningConfigItem -ne 0 ]; then
        echo "=== running client config: $runningConfigItem"
      fi
    fi

    clientConfigItem=0

    # read failover config file
    while read fcline
    do
      ParseFailoverConfigLine $fcline
      ret=$?
      echo "=== ret: $ret"
      if [ $ret -eq 0 ]; then
        continue
      elif [ $ret -eq 1 ]; then
        clientConfigSucc=1
      elif [ $ret -eq 2 ]; then
        LoadAndStartClientConfig $wgClientConfigFilePath
        if [ $? -eq 0 ]; then
          # try next config instead
          LogSlack "FILE FAIL: couldn't load the client config \'$wgClientConfigFilePath\', will try next"
          continue
        fi
      fi

      # finished with this after initial client config started/attached
      attachToRunningClient=0
      runningConfigItem=0
      
      # commence monitoring client health
      lhs=0
      unset wgShow
      nhs=0

      while true
      do
        # wait on wan being up
        WagWan $wanWait
        if [ $? -eq 1 ]; then
          # was down, so wait for a bit before continuing
          Log "WAN is back UP, waiting $wanUpAgainWait seconds before continuing"
          sleep $wanUpAgainWait
        fi

        testsFailed=""
        adv=$hsWait

        wgShow=$(wg show $wgc latest-handshakes)
        echo "=== wg show $wgc latest-handshakes: $wgShow"

        ifconfig=$(ifconfig $wgc 2>&1)
        echo "=== ifconfig $wgc: $ifconfig"

        # handle interface being shutdown, possibly in router ui
        if [ "$wgShow" == "Unable to access interface: No such device" ] || [ "$ifconfig" == "ifconfig: $wgc: error fetching interface information: Device not found" ]; then
          failMsg="INTERFACE FAIL: $wgc not found"
          if [ $quitOnNoInterface -eq 0 ]; then
            LogSlack "$failMsg - expiring current client config"
            #Log "$wgClientDescription: client config active since: "$upSince
            break
          else
            Exit 3 "$failMsg (with quitOnNoInterface enabled)"
          fi
        fi

        # calc how much time passed since last handshake
        dateNow=$(date +%s);                        echo dateNow: $dateNow
        dateLhs=`echo $wgShow | awk '{print $2}'`;  echo dateLhs: $dateLhs

        # if this is blank it probably means the client is stopped
        if [ "$dateLhs" != "" ]; then
          lhs=$(( $dateNow - $dateLhs ));   echo lhs: $lhs
        else
          LogSlack "HANDSHAKE FAIL: no handshake - assuming client is stopped, switching to next client config"
          break;
        fi

        # fail if lhs is nonsense
        if [ -z $lhs ] || [ -z $dateNow ] || [ $lhs -gt 1000000000 ]; then
          LogSlack "HANDSHAKE FAIL: value is nonsense\n\t\tdateNow: $dateNow\n\t\tdateLhs: $dateLhs\n\t\tlhs: $lhs"
          testsFailed="+Handshake"
        fi

        if [ $testPing -ne 0 ]; then
          TestPing
        fi

        if [ $testDns -ne 0 ]; then
          TestDNS $dnsServer
        fi

        if [ $testCurl -ne 0 ]; then
          TestCurl
        fi

        # failures can modify next handshake wait
        if [ "$testsFailed" != "" ]; then
          if [ $adv -lt 15 ]; then
            adv=15
          fi
          LogSlack "CONNECTIVITY FAIL: [$testsFailed+], reducing next handshake wait to $adv seconds"
        fi

        nhsm=$(( $nhs % $logEveryNthHandshake ))      
        nhs=$(( $nhs + 1 ))
        if [ $nhsm -eq 0 ]; then
          Log "$wgClientDescription: handshake #$nhs was $lhs secs ago"
        fi

        # give up on this client config if out of action for too long
        if [ $lhs -ge $hsTimeout ]; then
          LogSlack "HANDSHAKE FAIL: stale value of $lhs secs >= $hsTimeout, switching to next client config"
          break
        fi

        echo "=== sleeping for $adv secs"
        sleep $adv

        # check/handle if the monitored client config has changed
        DetectExternalRunningClientConfigChange; ret=$?
        if [ $ret -eq 1 ]; then
          LogSlack "CONNECTIVITY CHANGE: Continuing to monitor the externally loaded client config"
        elif [ $ret -eq 2 ]; then
          if [ $quitOnExternalAndUnmonitoredConfigChange -eq 1 ]; then
            Exit 12 "CONNECTIVITY CHANGE: Externally loaded client config NOT in failover config - change behaviour by removing \'--qoneuccc\' arg"
          else
            LogSlack "CONNECTIVITY CHANGE: Continuing to monitor the externally loaded client config, although NOT in failover config - change behaviour by adding \'--qoneuccc\' arg"
          fi
        elif [ $ret -eq 3 ]; then
          LogSlack "CONNECTIVITY CHANGE: settings \'$compareClientConfigDiff\' changed on router from the monitored client config \'$wgClientDescription\', will reload"
          LoadAndStartClientConfig $wgClientConfigFilePath
          if [ $? -eq 0 ]; then
            LogSlack "FILE FAIL: couldn't reload the client config \'$wgClientConfigFilePath\', will try next"
            runningConfigItem=0
            break
          fi
        elif [ $ret -eq 4 ]; then
          LogSlack "CONNECTIVITY CHANGE: Externally loaded client config NOT in failover config, will try next - change behaviour by removing \'--reload\' arg"
          runningConfigItem=0
          break
        fi
        
      done
    done < "$wgFailoverConfigFilePath"

    # check client config file loaded or running one found
    if [ $clientConfigSucc -eq 0 ]; then
      Exit 11 "FILE FAIL: client config not found in \'$wgFailoverConfigFilePath\'"
    fi
  done
}
