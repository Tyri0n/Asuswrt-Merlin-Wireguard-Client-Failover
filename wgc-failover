readonly _wanWait=30
readonly _disableWan1Check=0
readonly _attachToRunningClient=0
readonly _quitOnExternalAndUnmonitoredConfigChange=0
readonly _reloadClientConfigOnDiff=0

readonly _pingTargets="8.8.8.8,1.1.1.1,9.9.9.9"
readonly _nslookupTargets="google.com,amazon.com,cloudflare.com"
readonly _curlTargets=$_nslookupTargets

readonly _alive=25
readonly _firewall=1
