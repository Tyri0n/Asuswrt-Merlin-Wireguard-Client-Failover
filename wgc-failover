WaitForNTP()
{
  logged=0
  while true; do
    if [ $(nvram get ntp_ready) -ne 0 ]; then
      break
    fi
    if [ $logged -eq 0 ]; then
      Log "Wait for NTP to sync"
      logged=1
    fi
    sleep 30
  done

  if [ $logged -eq 1 ]; then
    Log "NTP sync success"
  fi
}

TestPing()
{
  echo ""; echo "============= test ping ============="

  StartTimer
  for ip in ${pingTargets//,/ }; do
    echo ""; echo "=== pinging $ip..."; echo ""
    ping -I $wgc -c 1 -w 1 $ip 2>&1
    if [ $? -eq 0 ]; then
      return
    fi
  done

  StopTimer
  adv=$(( $adv - $? ))

  testsFailed="$testsFailed+Ping"
}

TestDNS()
{
  if [ "$1" != "" ]; then
    echo ""; echo "============= test dns ============="

    StartTimer
    for domain in ${nslookupTargets//,/ }; do
      echo ""; echo "=== looking up $domain via $dnsServer..."; echo ""
      nslookup $domain $1 2>&1
      if [ $? -eq 0 ]; then
        return
      fi
    done

    StopTimer
    adv=$(( $adv - $? ))

    testsFailed="$testsFailed+DNS"
  fi
}

TestCurl()
{
  echo ""; echo "============= test curl ============="

  StartTimer
  for domain in ${curlTargets//,/ }; do
    echo ""; echo "=== curling $domain..."; echo ""
    curl -s --no-progress-meter --connect-timeout 5 --max-time 15 --interface $wgc $domain 2>&1
    if [ $? -eq 0 ]; then
      return
    fi
  done

  StopTimer
  adv=$(( $adv - $? ))

  testsFailed="$testsFailed+Curl"
  return 0
}

ParseFailoverConfigLine()
{
  line=$@
  echo "=== ParseFailoverConfigLine: $line"

  # skip blank line
  if [ "$line" == "" ]; then
    return 0
  fi

  fc=${line:0:1}
  # if line starts with # it's a comment
  if [[ $fc  == '#' ]]; then
    return 0
  fi
  # if line starts with dash then it's args
  if [[ $fc  == '-' ]]; then
    ParseArgs 1 "?" $line
    return 0
  fi

  # line is: 'filename' 'description'
  wgClientConfigFileName="$(echo $line | cut -d " " -f1)"
  wgClientDescription="$(echo $line | cut -d " " -f2)"

  # if filename starts with slash it's a full path
  fc=${wgClientConfigFileName:0:1}
  if [[ $fc  == '/' ]]; then
    wgClientConfigFilePath=$wgClientConfigFileName
    echo "=== client filename is full path: $wgClientConfigFilePath"
  else
    wgClientConfigFilePath=$wgClientConfigFilesDir/$wgClientConfigFileName
  fi

  clientConfigItem=$(( $clientConfigItem + 1 ))

  if ! [ -f $wgClientConfigFilePath ]; then
    Log "client config path \'$wgClientConfigFilePath\' is invalid"
    wgClientConfigFilePath=""
    clientConfigSucc=0
    return 0
  fi

  # check if we should attach or reload
  if [ $runningConfigItem -ne 0 ]; then
    if [ $clientConfigItem -eq $runningConfigItem ]; then

      # check if current configs settings are the same
      CompareClientConfigFile
      if [ "$compareClientConfigDiff" != "" ]; then
        LogSlack "Reloading the current runnning client config as some settings [$compareClientConfigDiff+] have been changed on the router"
        return 2
      fi

      # attach it is, then...
      LogSlack "Continuing with the current running client config: ($runningConfigItem) $wgClientDescription"
      return 1
    fi
    # try next line
    return 0
  fi

  # load this parsed client config
  return 2
}

LoadClientConfigFile()
{
  echo "=== LoadClientConfigFile"
  ParseClientConfigFile

  # set params in nvram
  nvram set "$wgc"_priv=$ccfg_priv
  nvram set "$wgc"_addr=$ccfg_addr
  nvram set "$wgc"_dns=$ccfg_dns
  nvram set "$wgc"_ppub=$ccfg_ppub
  nvram set "$wgc"_aips=$ccfg_aips
  nvram set "$wgc"_ep_addr=$ccfg_ep_addr
  nvram set "$wgc"_ep_port=$ccfg_ep_port
  nvram set "$wgc"_psk=$ccfg_psk

  nvram set "$wgc"_desc="$wgClientDescription"
  nvram set "$wgc"_alive=$_alive
  nvram set "$wgc"_enable=1
  nvram set "$wgc"_fw=$_firewall
  nvram set "$wgc"_nat=$_nat
  nvram set "$wgc"_enforce=$killswitch

  dnsServer="$ccfg_dns"
}

CompareClientConfigFile()
{
  echo "=== CompareClientConfigFile"

  compareClientConfigDiff=""
  if [ $reloadClientConfigOnDiff -ne 0 ]; then
    ParseClientConfigFile

    if [ "$(nvram get "$wgc"_priv)" != "$ccfg_priv" ]; then
      compareClientConfigDiff=$compareClientConfigDiff"+priv"
    fi
    if [ "$(nvram get "$wgc"_addr)" != "$ccfg_addr" ]; then
      compareClientConfigDiff=$compareClientConfigDiff"+addr"
    fi
    if [ "$(nvram get "$wgc"_dns)" != "$ccfg_dns" ]; then
      compareClientConfigDiff=$compareClientConfigDiff"+dns"
    fi
    if [ "$(nvram get "$wgc"_aips)" != "$ccfg_aips" ]; then
      compareClientConfigDiff=$compareClientConfigDiff"+aips"
    fi
    if [ "$(nvram get "$wgc"_ep_addr)" != "$ccfg_ep_addr" ]; then
      compareClientConfigDiff=$compareClientConfigDiff"+ep_addr"
    fi
    if [ "$(nvram get "$wgc"_ep_port)" != "$ccfg_ep_port" ]; then
      compareClientConfigDiff=$compareClientConfigDiff"+ep_port"
    fi
    if [ "$(nvram get "$wgc"_psk)" != "$ccfg_psk" ]; then
      compareClientConfigDiff=$compareClientConfigDiff"+psk"
    fi

    if [ "$(nvram get "$wgc"_alive)" != "$_alive" ]; then
      compareClientConfigDiff=$compareClientConfigDiff"+alive"
    fi
    if [ "$(nvram get "$wgc"_fw)" != "$_firewall" ]; then
      compareClientConfigDiff=$compareClientConfigDiff"+firewall"
    fi
    if [ "$(nvram get "$wgc"_nat)" != "$_nat" ]; then
      compareClientConfigDiff=$compareClientConfigDiff"+nat"
    fi
    if [ "$(nvram get "$wgc"_enforce)" != "$killswitch" ]; then
      compareClientConfigDiff=$compareClientConfigDiff"+killswitch"
    fi
  fi
}

ParseClientConfigFile()
{
  echo "=== ParseClientConfigFile"

  ccfg_priv=""
  ccfg_addr=""
  ccfg_dns=""
  ccfg_ppub=""
  ccfg_aips=""
  ccfg_ep_addr=""
  ccfg_ep_port=""
  ccfg_psk=""

  while read line
  do
    # skip blank line
    if [ "$line" == "" ]; then
      continue
    fi
    fc=${line:0:1}
    # if line starts with # it's a comment
    if [[ $fc  == '#' ]]; then
      continue
    fi
    if test "$line" != "${line%" = "*}" # remove spaces around equal sign to make formatting easy
    then
      lineFormatted="${line//" "/""}"
      if test "$lineFormatted" != "${lineFormatted%"PrivateKey"*}"; then
        ccfg_priv="${lineFormatted#*=}"
      elif test "$lineFormatted" != "${lineFormatted%"Address"*}"; then
        ccfg_addr="${lineFormatted#*=}"
      elif test "$lineFormatted" != "${lineFormatted%"DNS"*}"; then
        ccfg_dns="${lineFormatted#*=}"
      elif test "$lineFormatted" != "${lineFormatted%"PublicKey"*}"; then
        ccfg_ppub="${lineFormatted#*=}"
      elif test "$lineFormatted" != "${lineFormatted%"AllowedIPs"*}"; then
        ccfg_aips="${lineFormatted#*=}"
      elif test "$lineFormatted" != "${lineFormatted%"Endpoint"*}"; then
        endpointFull="${lineFormatted#*=}"
        ccfg_ep_addr="${endpointFull%:*}"
        ccfg_ep_port="${endpointFull#*:}"
      elif test "$lineFormatted" != "${lineFormatted%"PresharedKey"*}"; then
        ccfg_psk="${lineFormatted#*=}"
      fi
    fi
  done < "$wgClientConfigFilePath"
}

LoadAndStartClientConfig()
{
  path=$1
  echo "LoadAndStartClientConfig: $path"

  if ! [ -f $path ]; then
    LogSlack "FILE FAIL: client config path \'$wgClientConfigFilePath\' is invalid - trying next"
    wgClientConfigFilePath=""
    clientConfigSucc=0
    return 0
  fi

  wgClientConfigFilePath=$path

  if [ -n "$upSince" ]; then
    LogSlack "Previous client config was active since: $upSince"
    unset upSince
  fi

  LogSlack "Loading client config $wgClientConfigFilePath as $wgClientDescription\n\t"$(ParamsString)

  # stop client before changing client settings in nvram
  service "stop_wgc $clientNum"
  sleep 3

  # read client config file into variables and generate nvram set commands
  dnsServer=""
  LoadClientConfigFile
  clientConfigSucc=1
  
  # start client
  service "start_wgc $clientNum"
  upSince=$(date)
  sleep 3

  return 1
}

